# ============================================================
# AI AUTOMATION COMPANY — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- AI Provider Keys ---
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# --- Database ---
DATABASE_URL=postgresql://user:password@postgres:5432/appdb

# --- Security ---
# Master API key — used for machine-to-machine calls (n8n → backend)
API_SECRET_KEY=change-me-in-production

# JWT signing secret — used to sign/verify dashboard login tokens
JWT_SECRET_KEY=change-this-jwt-secret-in-production

# Shared secret for incoming webhooks (WhatsApp, n8n, etc.)
WEBHOOK_SECRET=webhook-secret-change-me

# --- Admin Dashboard Login ---
# First owner account — seeded automatically on first startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme
ADMIN_FIRST_NAME=Admin

# --- AI Defaults ---
DEFAULT_AI_PROVIDER=claude   # openai | claude | gemini

# --- n8n Automation ---
N8N_USER=admin
N8N_PASSWORD=changeme

# --- WhatsApp Cloud API (Meta) ---
# Get these from developers.facebook.com after creating a WhatsApp Business app
WHATSAPP_PHONE_NUMBER_ID=        # e.g. 123456789012345
WHATSAPP_ACCESS_TOKEN=           # permanent token from Meta System User
WHATSAPP_VERIFY_TOKEN=whatsapp-verify-changeme   # you choose this, must match Meta dashboard
WHATSAPP_CLIENT_ID=              # UUID of the client this WhatsApp line belongs to
WHATSAPP_BUSINESS_NAME=Your Business Name

# --- CRM Integrations ---
# HubSpot: Private App token from developers.hubspot.com → Private Apps
HUBSPOT_API_KEY=

# Zoho CRM: generate refresh token via api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# n8n webhook URL for new lead notifications (internal Docker URL)
N8N_NEW_LEAD_WEBHOOK=http://n8n:5678/webhook/crm-new-lead

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
